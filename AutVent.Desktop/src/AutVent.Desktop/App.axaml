<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AutVent.Desktop.App"
             xmlns:local="using:AutVent.Desktop"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <!-- Brand Colors -->
            <Color x:Key="BrandPrimary">#2563EB</Color>
            <Color x:Key="BrandPrimaryDark">#1D4ED8</Color>
            <Color x:Key="BrandPrimaryLight">#EFF6FF</Color>
            <Color x:Key="SurfaceWhite">#FFFFFF</Color>
            <Color x:Key="SurfaceGray">#F8FAFC</Color>
            <Color x:Key="SurfaceCard">#FFFFFF</Color>
            <Color x:Key="SidebarBackground">#0F172A</Color>
            <Color x:Key="SidebarItem">#1E293B</Color>
            <Color x:Key="SidebarItemActive">#2563EB</Color>
            <Color x:Key="TextPrimary">#0F172A</Color>
            <Color x:Key="TextSecondary">#475569</Color>
            <Color x:Key="TextMuted">#94A3B8</Color>
            <Color x:Key="BorderColor">#E2E8F0</Color>
            <Color x:Key="SuccessColor">#10B981</Color>
            <Color x:Key="DangerColor">#EF4444</Color>
            <Color x:Key="WarningColor">#F59E0B</Color>

            <!-- Solid Brushes -->
            <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimary}" />
            <SolidColorBrush x:Key="BrandPrimaryDarkBrush" Color="{StaticResource BrandPrimaryDark}" />
            <SolidColorBrush x:Key="BrandPrimaryLightBrush" Color="{StaticResource BrandPrimaryLight}" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackground}" />
            <SolidColorBrush x:Key="SidebarItemBrush" Color="{StaticResource SidebarItem}" />
            <SolidColorBrush x:Key="SidebarItemActiveBrush" Color="{StaticResource SidebarItemActive}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
            <SolidColorBrush x:Key="BorderColorBrush" Color="{StaticResource BorderColor}" />
            <SolidColorBrush x:Key="SurfaceGrayBrush" Color="{StaticResource SurfaceGray}" />
            <SolidColorBrush x:Key="SurfaceCardBrush" Color="{StaticResource SurfaceCard}" />
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

            <!-- Corner Radius Tokens -->
            <CornerRadius x:Key="RadiusSm">6</CornerRadius>
            <CornerRadius x:Key="RadiusMd">10</CornerRadius>
            <CornerRadius x:Key="RadiusLg">16</CornerRadius>
            <CornerRadius x:Key="RadiusXl">24</CornerRadius>

            <!-- Shadow -->
            <BoxShadows x:Key="ShadowCard">0 4 16 0 #14000000</BoxShadows>
            <BoxShadows x:Key="ShadowElevated">0 8 32 0 #1A000000</BoxShadows>

            <!-- Typography -->
            <x:Double x:Key="FontXs">11</x:Double>
            <x:Double x:Key="FontSm">13</x:Double>
            <x:Double x:Key="FontBase">14</x:Double>
            <x:Double x:Key="FontMd">16</x:Double>
            <x:Double x:Key="FontLg">20</x:Double>
            <x:Double x:Key="FontXl">24</x:Double>
            <x:Double x:Key="Font2Xl">30</x:Double>

            <!-- Reusable Styles -->
            <Style Selector="Button.Primary" x:Key="PrimaryButton">
                <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
                <Setter Property="Padding" Value="20,10" />
                <Setter Property="FontSize" Value="{StaticResource FontBase}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>

            <Style Selector="Button.Danger" x:Key="DangerButton">
                <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
                <Setter Property="Padding" Value="20,10" />
                <Setter Property="FontSize" Value="{StaticResource FontBase}" />
            </Style>

            <Style Selector="Button.Ghost" x:Key="GhostButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
                <Setter Property="Padding" Value="16,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
